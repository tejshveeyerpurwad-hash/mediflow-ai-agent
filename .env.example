# ── SwasthAI Guardian — Environment Variables Template ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Backend
PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
GROQ_API_KEY=gsk_your_groq_api_key_here
AI_SERVICE_URL=http://localhost:8000

# CORS — comma-separated list of allowed frontend origins
# For local dev: http://localhost:5173
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# Agentic Outbreak Monitor auth header (required in production)
AGENT_SECRET=change_this_to_a_random_secret

# Aadhaar hashing salt (required in production)
AADHAAR_SALT=change_this_to_a_random_32_char_secret

# Development only: allow demo OTP 1234 (never enable in production)
# ALLOW_DEMO_OTP=true

# Cluster workers (use 1 on Render/Fargate free tier)
NODE_CLUSTER_WORKERS=1

# AWS DynamoDB (optional locally — mock mode without these)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI Service
# (GROQ_API_KEY and AGENT_SECRET are shared — set once above)

# Frontend
VITE_API_URL=http://localhost:5000/api

