# ── MediFlow AI Environment Variables ───────────────────────────────────────────
# Copy to .env and fill in your values

# Backend
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-random-string
JWT_SECRET=change-me-to-random-string-wp9jf3
ADMIN_PASSCODE=mediflow-admin-secret-2026

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Groq (primary AI provider)
GROQ_API_KEY=gsk_your_groq_api_key_here

# AWS Bedrock (fallback AI provider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-v3-sonnet

# Database
DATABASE_URL=sqlite:///data/mediflow.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/mediflow

# SMS / WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Maps (for hospital recommendation)
MAPS_API_KEY=
